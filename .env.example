# ─────────────────────────────────────────────────────────
# NDC DIAGNOSTIC CENTRE – Queue Management System
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────────────────

# PostgreSQL database connection string
DATABASE_URL=postgresql://ndc_user:ndc_pass@postgres:5432/ndc_qms

# Redis connection (used for pub/sub and optional job queue)
REDIS_URL=redis://redis:6379

# API server port
API_PORT=4000

# Next.js web port
WEB_PORT=3000

# ── Reception Proxy (fill in when you have the actual endpoint) ──
# Base URL of the external registration proxy
RECEPTION_PROXY_BASE_URL=https://proxy.example.com
# API key provided by your reception software vendor
RECEPTION_PROXY_API_KEY=your-api-key-here
# Timeout in milliseconds for proxy requests (default 10 seconds)
RECEPTION_PROXY_TIMEOUT_MS=10000
# How often to poll for new registrations (milliseconds, default 60 seconds)
RECEPTION_POLL_INTERVAL_MS=60000

# ── Internal tokens ──
# Secret used to sign internal tokens (change this to a random string!)
JWT_SECRET=change-me-to-a-random-secret

# ── Environment ──
NODE_ENV=production
