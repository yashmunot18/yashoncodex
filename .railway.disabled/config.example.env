# Railway Environment Variable Reference
# ─────────────────────────────────────────────────────────────
# Copy the variable NAMES (left side of =) into the Railway
# dashboard under each service's "Variables" tab.
# Replace the placeholder VALUES with your real values.
# ⚠️  Never commit real secrets to this file.
# ─────────────────────────────────────────────────────────────

# ── Database (Postgres add-on) ────────────────────────────────
# Railway auto-fills this when you add the Postgres plugin.
# Format: postgresql://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql://ndc_user:ndc_pass@your-db-host:5432/ndc_qms

# ── Cache (Redis add-on) ──────────────────────────────────────
# Railway auto-fills this when you add the Redis plugin.
REDIS_URL=redis://your-redis-host:6379

# ── Reception Proxy (fill in your values) ────────────────────
# Base URL of your reception software API (no trailing slash).
RECEPTION_PROXY_BASE_URL=

# API key issued by your reception software provider.
RECEPTION_PROXY_API_KEY=

# ── Service Ports ─────────────────────────────────────────────
# Railway assigns a public port automatically; these are the
# internal listening ports used inside the container.
API_PORT=4000
WEB_PORT=3000
